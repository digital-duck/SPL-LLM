{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "SPL",
    "scopeName": "source.spl",
    "patterns": [
        { "include": "#comments" },
        { "include": "#strings" },
        { "include": "#variables" },
        { "include": "#exception_types" },
        { "include": "#types" },
        { "include": "#keywords" },
        { "include": "#function_calls" },
        { "include": "#numbers" },
        { "include": "#operators" },
        { "include": "#function_body" }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.double-dash.spl",
                    "match": "--.*$"
                },
                {
                    "name": "comment.block.spl",
                    "begin": "/\\*",
                    "end": "\\*/"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.spl",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        { "name": "constant.character.escape.spl", "match": "\\\\." }
                    ]
                },
                {
                    "name": "string.quoted.single.spl",
                    "begin": "'",
                    "end": "'",
                    "patterns": [
                        { "name": "constant.character.escape.spl", "match": "\\\\." }
                    ]
                }
            ]
        },
        "variables": {
            "patterns": [
                {
                    "comment": "SPL 2.0 variable references: @var_name",
                    "name": "variable.other.spl",
                    "match": "@[a-zA-Z_][a-zA-Z0-9_]*"
                },
                {
                    "comment": "memory.key and context.field dotted access",
                    "match": "\\b(memory|context)\\.([a-zA-Z_][a-zA-Z0-9_]*)",
                    "captures": {
                        "1": { "name": "support.variable.namespace.spl" },
                        "2": { "name": "variable.other.member.spl" }
                    }
                }
            ]
        },
        "exception_types": {
            "patterns": [
                {
                    "comment": "SPL 2.0 built-in exception type names",
                    "name": "support.type.exception.spl",
                    "match": "\\b(HallucinationDetected|RefusalToAnswer|ContextLengthExceeded|ModelOverloaded|QualityBelowThreshold|MaxIterationsReached|BudgetExceeded|NodeUnavailable)\\b"
                }
            ]
        },
        "types": {
            "patterns": [
                {
                    "comment": "SPL 2.0 data types used in INPUT/OUTPUT/RETURNS declarations",
                    "name": "support.type.spl",
                    "match": "(?i)\\b(TEXT|NUMBER|BOOLEAN|LIST|JSON)\\b"
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "comment": "Top-level statement declarations",
                    "name": "keyword.declaration.spl",
                    "match": "(?i)\\b(PROMPT|WORKFLOW|PROCEDURE)\\b"
                },
                {
                    "comment": "CREATE FUNCTION / CREATE PROCEDURE",
                    "match": "(?i)\\b(CREATE)\\s+(FUNCTION|PROCEDURE)\\b",
                    "captures": {
                        "1": { "name": "keyword.declaration.spl" },
                        "2": { "name": "keyword.declaration.spl" }
                    }
                },
                {
                    "comment": "SPL 2.0 workflow control-flow keywords",
                    "name": "keyword.control.flow.spl",
                    "match": "(?i)\\b(DO|END|EVALUATE|WHEN|THEN|OTHERWISE|WHILE|CALL|COMMIT|RAISE|RETRY|EXCEPTION|INPUT|OUTPUT|INTO)\\b"
                },
                {
                    "comment": "SELECT/FROM query clause keywords",
                    "name": "keyword.control.query.spl",
                    "match": "(?i)\\b(SELECT|FROM|AS|WHERE|ORDER\\s+BY|ASC|DESC|IN|AND|OR|NOT|LIMIT|RETURNS)\\b"
                },
                {
                    "comment": "GENERATE — core LLM invocation keyword",
                    "name": "keyword.other.generate.spl",
                    "match": "(?i)\\b(GENERATE|EXECUTE|EXPLAIN)\\b"
                },
                {
                    "comment": "STORE RESULT IN memory.<key>",
                    "match": "(?i)\\b(STORE)\\s+(RESULT)\\s+(IN)\\b",
                    "captures": {
                        "1": { "name": "keyword.other.spl" },
                        "2": { "name": "keyword.other.spl" },
                        "3": { "name": "keyword.other.spl" }
                    }
                },
                {
                    "comment": "WITH BUDGET <n> TOKENS",
                    "match": "(?i)\\b(WITH)\\s+(BUDGET)\\b",
                    "captures": {
                        "1": { "name": "keyword.other.spl" },
                        "2": { "name": "keyword.other.spl" }
                    }
                },
                {
                    "comment": "USING MODEL '<model>' — inline model override",
                    "begin": "(?i)\\b(USING)\\s+(MODEL)\\b",
                    "beginCaptures": {
                        "1": { "name": "keyword.other.spl" },
                        "2": { "name": "keyword.other.spl" }
                    },
                    "end": "(?i)(?=\\s*(;|WITH|CACHE|SELECT|GENERATE|STORE|$))",
                    "patterns": [
                        { "include": "#strings" },
                        {
                            "match": "\\b[a-zA-Z_][a-zA-Z0-9_.\\-]*\\b",
                            "name": "entity.name.type.model.spl"
                        }
                    ]
                },
                {
                    "comment": "Token / output / temperature option keywords",
                    "name": "keyword.other.spl",
                    "match": "(?i)\\b(TOKENS|MODEL|CACHE|OUTPUT|TEMPERATURE|FORMAT|STORE|RESULT|PARAMS|WITH|BUDGET|RETURNS|USING)\\b"
                }
            ]
        },
        "function_calls": {
            "patterns": [
                {
                    "comment": "SPL 2.0 built-in generation functions",
                    "match": "(?i)\\b(summarize|translate|classify|extract_entities|sentiment|answer|rewrite|generate_code|greeting)(?=\\s*\\()",
                    "name": "support.function.builtin.spl"
                },
                {
                    "comment": "Context, memory, and utility functions",
                    "match": "(?i)\\b(system_role|rag)(?=\\s*\\()",
                    "name": "support.function.builtin.spl"
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.spl",
                    "match": "\\b[0-9]+(\\.[0-9]+)?\\b"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "comment": "SPL 2.0 variable assignment := ",
                    "name": "keyword.operator.assignment.spl",
                    "match": ":="
                },
                {
                    "comment": "Comparison operators",
                    "name": "keyword.operator.comparison.spl",
                    "match": "(>=|<=|!=|<>|=|>|<)"
                },
                {
                    "comment": "Statement terminator",
                    "name": "punctuation.terminator.statement.spl",
                    "match": ";"
                }
            ]
        },
        "function_body": {
            "comment": "CREATE FUNCTION body delimited by $$...$$",
            "begin": "\\$\\$",
            "end": "\\$\\$",
            "beginCaptures": { "0": { "name": "punctuation.definition.heredoc.spl" } },
            "endCaptures":   { "0": { "name": "punctuation.definition.heredoc.spl" } },
            "name": "meta.embedded.function-body.spl",
            "patterns": [
                { "include": "#comments" },
                { "include": "#strings" },
                { "include": "#variables" },
                { "include": "#keywords" },
                { "include": "#function_calls" },
                { "include": "#numbers" },
                { "include": "#operators" }
            ]
        }
    }
}
